# Copy this file to `.env` before running the Docker Compose workflow.
# These defaults target the container network defined in docker-compose.yml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=deep_research
DEEP_RESEARCH_MODEL_PROVIDER=openai
DEEP_RESEARCH_MODEL_NAME=gpt-4.1-mini
DEEP_RESEARCH_OPENAI_API_KEY=
DEEP_RESEARCH_OPENAI_BASE_URL=https://api.openai.com/v1
DEEP_RESEARCH_OLLAMA_BASE_URL=http://host.docker.internal:11434
DEEP_RESEARCH_PERSISTENCE_BACKEND=postgres
DEEP_RESEARCH_SQLITE_DB_URL=sqlite+aiosqlite:///./.local/deep_research.sqlite3
DEEP_RESEARCH_DEFAULT_SEARCH_PROVIDER=none
DEEP_RESEARCH_SEARXNG_REGISTRY_URL=https://searx.space/data/instances.json
DEEP_RESEARCH_SEARXNG_LOCAL_URL=http://searxng:8080
DEEP_RESEARCH_SEARXNG_POOL_SIZE=5
DEEP_RESEARCH_TAVILY_API_KEY=
DEEP_RESEARCH_SERPER_API_KEY=
DEEP_RESEARCH_TOTAL_TOKEN_BUDGET=120000
DEEP_RESEARCH_PER_SOURCE_TOKEN_BUDGET=4000
DEEP_RESEARCH_MAX_CONTENT_CHARS_PER_SOURCE=16000
DEEP_RESEARCH_MAX_SOURCES_PER_TASK=8
DEEP_RESEARCH_MAX_NOTES=200
DEEP_RESEARCH_MAX_ITERATIONS=6
DEEP_RESEARCH_HTTP_USER_AGENT=deep-research-agent/0.1.0
